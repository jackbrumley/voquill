<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>org.voquill.foss</id>
  <name>Voquill</name>
  <summary>Push-to-talk dictation app with local transcription</summary>
  <project_license>MIT</project_license>
  <metadata_license>CC0-1.0</metadata_license>
  <developer id="org.voquill">
    <name>Jack Brumley</name>
  </developer>
  <pkgname>voquill</pkgname>
  <launchable type="desktop-id">org.voquill.foss.desktop</launchable>
  <icon type="stock">org.voquill.foss</icon>
  <icon type="stock">voquill</icon>
  <description>
    <p>
      Voquill is a cross-platform push-to-talk dictation app for Linux and Windows. Hold your shortcut to record,
      release to transcribe, and Voquill types directly into your active application.
    </p>
    <p>
      It is local-first by design: voice processing can run entirely on-device with Whisper models, and cloud API
      transcription is optional.
    </p>
    <p>
      Voquill is built for a clean desktop workflow with explicit Wayland portal permissions, reliable Linux and Windows
      behavior, and fast keyboard-first dictation.
    </p>
  </description>
  <url type="homepage">https://voquill.org/</url>
  <url type="bugtracker">https://github.com/jackbrumley/voquill/issues</url>
  <url type="vcs-browser">https://github.com/jackbrumley/voquill</url>
  <categories>
    <category>Utility</category>
    <category>Office</category>
    <category>AudioVideo</category>
  </categories>
