<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>org.voquill.foss</id>
  <name>Voquill</name>
  <summary>Push-to-talk dictation app with local transcription</summary>
  <project_license>MIT</project_license>
  <metadata_license>CC0-1.0</metadata_license>
  <developer id="org.voquill">
    <name>Jack Brumley</name>
  </developer>
  <launchable type="desktop-id">org.voquill.foss.desktop</launchable>
  <description>
    <p>
      Voquill is a cross-platform push-to-talk dictation app for Linux and Windows. It records while your shortcut is held,
      transcribes locally or via API, and types into your active application.
    </p>
    <p>
      It is focused on a clean desktop workflow with explicit portal permissions on Wayland and local-first operation.
    </p>
  </description>
  <url type="homepage">https://voquill.org/</url>
  <url type="bugtracker">https://github.com/jackbrumley/voquill/issues</url>
  <url type="vcs-browser">https://github.com/jackbrumley/voquill</url>
  <categories>
    <category>Utility</category>
    <category>Office</category>
    <category>AudioVideo</category>
  </categories>
  <content_rating type="oars-1.1"/>
  <screenshots>
